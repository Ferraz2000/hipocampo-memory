{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m hipocampo.hooks.session_start",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m hipocampo.hooks.capture_sweep",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
